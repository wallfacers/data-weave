{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "weft:file-contract/task",
  "title": "TaskDoc (<slug>.task.yaml)",
  "description": "脚本体在独立文件 <slug>.<ext>(扩展名由 type 映射)。身份=文件名 slug。",
  "type": "object",
  "required": ["formatVersion", "name", "type"],
  "properties": {
    "formatVersion": { "type": "integer", "const": 1 },
    "name": { "type": "string", "description": "显示名(可中文/空格/重名)" },
    "type": { "type": "string", "description": "开放字符串:SQL/SHELL/PYTHON/DATA_SYNC/ECHO 等(非穷举)" },
    "description": { "type": "string" },
    "priority": { "type": "integer", "minimum": 0, "maximum": 9 },
    "timeoutSec": { "type": "integer", "minimum": 0 },
    "retryMax": { "type": "integer", "minimum": 0 },
    "frozen": { "type": "boolean" },
    "datasource": { "type": "string", "description": "数据源逻辑 code" },
    "targetDatasource": { "type": "string", "description": "目标数据源逻辑 code" },
    "params": { "type": "object", "description": "参数 map(键升序);读回规范 JSON 串" },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "引用 tags.yaml 的 name,升序"
    }
  },
  "additionalProperties": false
}
